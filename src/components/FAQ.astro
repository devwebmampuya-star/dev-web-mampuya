---
const faqs = [
  { q: "Quel est le délai de livraison standard pour un site web premium ?", a: "Le délai varie de 2 à 6 semaines selon la complexité fonctionnelle et l'intégration des automatisations ou d'Intelligences Artificielles." },
  { q: "Pourquoi utilisez-vous le framework Astro 5 plutôt que WordPress ?", a: "Astro 5 génère du HTML statique sans JavaScript lourd par défaut. Cela garantit un chargement instantané, un score Lighthouse supérieur à 95 et un référencement Google optimisé au maximum." },
  { q: "Pouvez-vous automatiser notre support client via WhatsApp ?", a: "Oui, nous concevons des chatbots intelligents connectés aux API OpenAI pour répondre à vos clients, qualifier vos prospects et synchroniser vos données 24h/24 sans intervention humaine." },
  { q: "L'agence gère-t-elle les campagnes publicitaires internationales ?", a: "Absolument. Nos experts configurent des funnels de conversion haut de gamme pour Facebook Ads et Instagram Ads ciblant des audiences qualifiées en Afrique et à l'échelle mondiale." }
];
---

<section id="faq" class="py-32 bg-dark-900 relative">
  <div class="container mx-auto max-w-4xl px-4">
    <div class="text-center mb-20">
      <h2 class="text-xs uppercase font-bold tracking-widest text-[#00FF66] mb-4">FAQ Stratégique</h2>
      <p class="text-3xl md:text-4xl font-black text-white uppercase tracking-tight">Réponses à vos Questions Clés</p>
    </div>
    
    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group border border-white/5 rounded-xl bg-neutral-900/40 overflow-hidden backdrop-blur-md transition-all duration-300 [&_summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between p-6 text-left font-bold text-white group-open:text-[#00FF66] hover:text-[#00FF66] transition-colors cursor-pointer list-none select-none">
            <span class="text-sm md:text-base uppercase tracking-wider">{faq.q}</span>
            <span class="text-xl font-light text-[#D4AF37] transition-transform duration-300 group-open:rotate-45">+</span>
          </summary>
          <div class="p-6 pt-0 text-xs md:text-sm text-neutral-400 font-light leading-relaxed border-t border-white/5 bg-black/20">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>