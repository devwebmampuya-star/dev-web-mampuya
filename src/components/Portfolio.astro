---
const projects = [
  { category: 'Sites Web', title: 'Corporate Portal - Mining Industry', img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80', desc: 'Astro 5 & TailwindCSS architecture' },
  { category: 'E-commerce', title: 'Luxury Retail Hub', img: 'https://images.unsplash.com/photo-1511556532299-8f662fc26c06?auto=format&fit=crop&w=800&q=80', desc: 'Shopify Premium headless implementation' },
  { category: 'Applications', title: 'Fintech Mobile Dashboard', img: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80', desc: 'Realtime banking API integrations' },
  { category: 'Branding', title: 'Visual Identity Neo-Bank', img: 'https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&w=800&q=80', desc: 'Complete high-end corporate identity' },
  { category: 'Marketing', title: 'Acquisition Campaign DRC', img: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80', desc: 'Meta Ads funnel maximizing conversions' },
  { category: 'Sites Web', title: 'ONG International Website', img: 'https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=800&q=80', desc: 'High availability clean architecture' }
];
---
<section id="portfolio" class="py-32 bg-neutral-950 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-xs uppercase font-bold tracking-widest text-[#D4AF37] mb-4">Galerie de Réalisations Élite</h2>
      <p class="text-3xl md:text-5xl font-black text-white uppercase tracking-tight">Nos Derniers Masterpieces</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((p) => (
        <div class="group rounded-2xl overflow-hidden bg-neutral-900/50 border border-white/10 p-6 hover:border-[#00FF66]/30 transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,255,102,0.05)]">
          <div class="overflow-hidden rounded-xl mb-4 h-48">
            <img src={p.img} alt={p.title} class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700" />
          </div>
          <span class="text-[10px] font-bold text-[#00FF66] uppercase bg-[#00FF66]/10 px-2.5 py-1 rounded-md tracking-wider">{p.category}</span>
          <h3 class="text-xl font-bold text-white mt-3 mb-1 group-hover:text-[#00FF66] transition-colors">{p.title}</h3>
          <p class="text-neutral-400 text-xs font-light mb-4">{p.desc}</p>
          <a href="#" class="inline-flex items-center text-xs font-semibold text-[#D4AF37] hover:text-white transition-colors">
            Explorer l'étude de cas <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>