---
// Services.astro — Agence Digitale DEV WEB MAMPUYA
import { Code2, LayoutDashboard, Cpu, MessageSquareCode, Globe, Smartphone } from 'lucide-react';

const services = [
  {
    icon: Code2,
    title: "Ingénierie Web & Applications",
    description: "Développement d'architectures robustes, d'applications métiers sur mesure et de plateformes SaaS hautement scalables."
  },
  {
    icon: LayoutDashboard,
    title: "Solutions Core Banking & FinTech",
    description: "Conception de systèmes de microfinance et de core banking modernes, sécurisés et adaptés aux réalités du marché."
  },
  {
    icon: Cpu,
    title: "Intégration IA & IoT (AIoT)",
    description: "Automatisation intelligente, interconnexion d'objets connectés et déploiement de modèles d'IA pour optimiser vos processus."
  },
  {
    icon: Globe,
    title: "Sites Vitrines & Écosystèmes 360°",
    description: "Création de sites premium à forte conversion, optimisés pour le SEO et offrant des performances d'affichage instantanées."
  },
  {
    icon: Smartphone,
    title: "Applications Mobiles Cross-Platform",
    description: "Développement d'expériences mobiles fluides et intuitives sur iOS et Android à partir d'une base de code unique."
  },
  {
    icon: MessageSquareCode,
    title: "Consulting Stratégique & DBA",
    description: "Audit d'architecture, optimisation de bases de données complexes (PostgreSQL) et accompagnement technique de pointe."
  }
];
---

<section id="services" class="py-24 bg-black border-b border-white/5 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(0,255,102,0.03),transparent_50%)]"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl mb-16">
      <span class="text-xs font-bold tracking-widest text-[#00FF66] uppercase bg-[#00FF66]/10 px-3 py-1 rounded-full">
        Nos Expertises
      </span>
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-white mt-4 mb-6 uppercase">
        Des solutions digitales d'élite <br />pour propulser votre business.
      </h2>
      <p class="text-neutral-400 text-lg">
        Nous fusionnons design de pointe, ingénierie logicielle avancée et architectures modernes pour créer un impact réel sur votre croissance.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => {
        const IconComponent = service.icon;
        return (
          <div class="group bg-neutral-950 border border-white/5 hover:border-[#00FF66]/30 p-8 rounded-2xl transition-all duration-300 hover:-translate-y-1 flex flex-col justify-between">
            <div>
              <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-white group-hover:bg-[#00FF66]/10 group-hover:text-[#00FF66] group-hover:border-[#00FF66]/20 transition-all duration-300 mb-6">
                {/* Correction TypeScript : Utilisation de className au lieu de class */}
                <IconComponent className="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#00FF66] transition-colors duration-300">
                {service.title}
              </h3>
              <p class="text-neutral-400 text-sm leading-relaxed">
                {service.description}
              </p>
            </div>
            
            <div class="mt-6 pt-6 border-t border-white/5 flex items-center text-xs font-bold tracking-wider text-neutral-500 group-hover:text-white transition-colors duration-300 uppercase gap-2">
              En savoir plus 
              <span class="transform group-hover:translate-x-1 transition-transform duration-300">→</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>