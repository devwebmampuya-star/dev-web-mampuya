---
// Section Hero Astro Native — Dev Web MAMPUYA
// Remplacement des icônes React par du SVG inline ultra-léger et rapide
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-dark-900 pt-24 px-4">
  <!-- Fond technologique IA & Grille de lumière -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#0f0f12_1px,transparent_1px),linear-gradient(to_bottom,#0f0f12_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
  
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-premium-neon/10 rounded-full blur-[120px] pointer-events-none animate-pulse"></div>
  <div class="absolute bottom-1/4 left-1/3 w-[300px] h-[300px] bg-premium-gold/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="container mx-auto max-w-6xl relative z-10 text-center">
    <!-- Badge Premium -->
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-dark-800/80 border border-white/10 backdrop-blur-md mb-8">
      <span class="w-2 h-2 rounded-full bg-[#00FF66] relative flex">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00FF66] opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00FF66]"></span>
      </span>
      <span class="text-xs font-semibold tracking-widest uppercase text-white">Basé à Kinshasa • Disponible dans le monde entier</span>
    </div>

    <!-- Titre H1 Awwwards Style -->
    <h1 class="text-5xl md:text-8xl font-black tracking-tighter text-white mb-6 uppercase select-none">
      DEV WEB <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00FF66] via-white to-[#D4AF37]">MAMPUYA</span>
    </h1>

    <!-- Sous-titre Stratégique -->
    <p class="text-lg md:text-2xl text-neutral-400 max-w-3xl mx-auto font-light leading-relaxed mb-12">
      Agence Digitale 360° spécialisée dans le <span class="text-white font-medium">Développement Web</span>, l'<span class="text-[#00FF66] font-medium">Intelligence Artificielle</span> et le <span class="text-[#D4AF37] font-medium">Marketing Digital</span>.
    </p>

    <!-- Boutons d'actions CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
      <a 
        href="#contact" 
        class="w-full sm:w-auto inline-block bg-[#00FF66] text-black font-black uppercase text-xs tracking-widest px-8 py-4 rounded-xl hover:bg-white transition-all duration-300 transform hover:-translate-y-0.5 shadow-[0_4px_20px_rgba(0,255,102,0.3)] text-center cursor-pointer"
      >
        Démarrer un Projet Maintenant
      </a>
      
      <a 
        href="#portfolio" 
        class="px-8 py-4 w-full sm:w-auto rounded-xl font-bold text-white bg-neutral-900 border border-white/10 backdrop-blur-md hover:bg-neutral-800 transition-colors flex items-center justify-center gap-2 text-center"
      >
        <span>Voir nos réalisations</span>
      </a>
      
      <a 
        href="https://wa.me/243833583517" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="px-8 py-4 w-full sm:w-auto rounded-xl font-bold text-[#D4AF37] bg-neutral-900/40 border border-[#D4AF37]/30 backdrop-blur-md hover:bg-[#D4AF37]/10 transition-colors flex items-center justify-center gap-2 text-center"
      >
        <!-- SVG Natif MessageCircle (Lucide) -->
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
        <span>Contact WhatsApp</span>
      </a>
    </div>

    <!-- Statistiques Flottantes -->
    <div id="stats-hero" class="grid grid-cols-2 md:grid-cols-4 gap-8 pt-12 border-t border-white/5 bg-neutral-900/20 backdrop-blur-md rounded-2xl p-6">
      <div>
        <h3 class="text-3xl md:text-5xl font-bold text-white" data-target="150">0</h3>
        <p class="text-xs uppercase tracking-widest text-neutral-400 mt-2">Projets réalisés</p>
      </div>
      <div>
        <h3 class="text-3xl md:text-5xl font-bold text-[#00FF66]" data-target="99">0</h3>
        <p class="text-xs uppercase tracking-widest text-neutral-400 mt-2">Satisfaction Client</p>
      </div>
      <div>
        <h3 class="text-3xl md:text-5xl font-bold text-white" data-target="5">0</h3>
        <p class="text-xs uppercase tracking-widest text-neutral-400 mt-2">Pays touchés</p>
      </div>
      <div>
        <h3 class="text-3xl md:text-5xl font-bold text-[#D4AF37]" data-target="24">0</h3>
        <p class="text-xs uppercase tracking-widest text-neutral-400 mt-2">Support Premium</p>
      </div>
    </div>
  </div>
</section>

<!-- Script exécuté uniquement côté client -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  if (typeof window !== 'undefined') {
    gsap.registerPlugin(ScrollTrigger);

    // Animation ultra-pro des compteurs numériques avec GSAP
    const counters = document.querySelectorAll("#stats-hero h3");
    
    counters.forEach((counter) => {
      const targetValue = parseInt(counter.getAttribute("data-target") || "0", 10);
      
      gsap.fromTo(counter, 
        { textContent: 0 },
        {
          textContent: targetValue,
          duration: 2.5,
          ease: "power4.out",
          snap: { textContent: 1 },
          scrollTrigger: {
            trigger: "#stats-hero",
            start: "top 95%",
            toggleActions: "play none none none"
          },
          onComplete: () => {
            // Rajout des suffixes professionnels personnalisés après la fin du décompte
            if (targetValue === 150) counter.textContent = "150+";
            if (targetValue === 99) counter.textContent = "99%";
            if (targetValue === 5) counter.textContent = "5+";
            if (targetValue === 24) counter.textContent = "24/7";
          }
        }
      );
    });
  }
</script>